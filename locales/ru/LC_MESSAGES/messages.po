msgstr "✅ Принять"

#: src/bot/handlers/commands/start.py:37 src/bot/handlers/commands/start.py:76
#: src/bot/handlers/commands/start.py:81
msgid "❌ Decline"
msgstr "❌ Отклонить"

#: src/bot/handlers/commands/start.py:43
msgid "📱 Share Phone"
msgstr "📱 Поделиться контактом"

#: src/bot/handlers/commands/start.py:44
#: src/bot/handlers/schedules/create.py:36
#: src/bot/handlers/schedules/create.py:42
msgid "➡️ Skip"
msgstr "➡️ Пропустить"

#: src/bot/handlers/commands/start.py:50 src/bot/handlers/commands/start.py:191
msgid "🌍 Share Location"
msgstr "🌍 Поделиться местоположением"

#: src/bot/handlers/commands/start.py:58
msgid "Welcome back! Use /schedule to manage medications."
msgstr "С возвращением! Используйте /schedule для создания расписания."

#: src/bot/handlers/commands/start.py:62
msgid ""
"👋 Welcome to MedTimely!\n"
"\n"
"Before we start, please:\n"
"1. Read our [Privacy Policy](https://tnfy.link/5nBW)\n"
"2. Confirm you agree with data processing"
msgstr ""
"👋 Добро пожаловать в ПилюляБот!\n"
"\n"
"Перед тем как начать, пожалуйста:\n"
"1. Прочитайте нашу [Политику конфиденциальности](https://tnfy.link/5nBW)\n"
"2. Подтвердите, что вы согласны с обработкой данных"

#: src/bot/handlers/commands/start.py:83
msgid "❌ You must accept the privacy policy to use this service."
msgstr "❌ Необходимо принять политику конфиденциальности, чтобы использовать бота."

#: src/bot/handlers/commands/start.py:92
msgid ""
"Thank you for accepting our privacy policy! 🎉\n"
"\n"
"Would you like to share your phone number for emergency contacts?"
msgstr ""
"Спасибо, что приняли нашу политику конфиденциальности! 🎉\n"
"\n"
"Хотите поделиться своим номером телефона для возможности восстановления "
"доступа?"

#: src/bot/handlers/commands/start.py:104
msgid "Please use the buttons to accept or decline the privacy policy."
msgstr ""
"Пожалуйста, используйте кнопки, чтобы принять или отклонить политику "
"конфиденциальности."

#: src/bot/handlers/commands/start.py:117
msgid "⚠️ Please share your phone number."
msgstr "⚠️ Пожалуйста, поделитесь своим номером телефона."

#: src/bot/handlers/commands/start.py:121
msgid "⚠️ Please share your own phone number."
msgstr ""
"⚠️ Пожалуйста, поделитесь своим собственным номером телефона. Он должен "
"совпадать с номером телефона в профиле Telegram."

#: src/bot/handlers/commands/start.py:127
msgid "✅ Phone number saved!"
msgstr "✅ Номер телефона сохранен!"

#: src/bot/handlers/commands/start.py:131
msgid "You can add phone later in profile."
msgstr "Вы можете добавить телефон позже в профиль."

#: src/bot/handlers/commands/start.py:134
msgid "Please use the buttons below to share phone or skip."
msgstr ""
"Пожалуйста, используйте кнопки ниже, чтобы поделиться контактом или "
"пропустить."

#: src/bot/handlers/commands/start.py:138
msgid ""
"🌍 For accurate medication reminders, we need your timezone.\n"
"\n"
"Please either:\n"
"1. Share your current location\n"
"2. Send your local time (e.g. 14:30)"
msgstr ""
"🌍 Для точных напоминаний о приеме лекарств нам нужен Ваш часовой пояс.\n"
"\n"
"Пожалуйста, либо:\n"
"1. Поделитесь своим текущим местоположением\n"
"2. Отправьте свое местное время (например, 14:30)"

#: src/bot/handlers/commands/start.py:151
msgid "Please use the buttons to share phone number or skip."
msgstr "Пожалуйста, используйте кнопки, чтобы поделиться контактом или пропустить."

#: src/bot/handlers/commands/start.py:168
#: src/bot/handlers/commands/start.py:174
#, python-brace-format
msgid "✅ Timezone detected: {tz}"
msgstr "✅ Определен часовой пояс: {tz}"

#: src/bot/handlers/commands/start.py:181
#, python-brace-format
msgid "✅ Timezone set to {tz} (UTC{offset:+g})"
msgstr "✅ Часовой пояс установлен на {tz} (UTC{offset:+g})"

#: src/bot/handlers/commands/start.py:193
msgid "📍 Multiple matches found. Please choose the most suitable timezone:"
msgstr ""
"📍 Найдено несколько совпадений. Пожалуйста, выберите наиболее подходящий "
"часовой пояс:"

#: src/bot/handlers/commands/start.py:202
msgid ""
"\n"
"\n"
"💊 Now let's create your first medication schedule!\n"
"\n"
"Use /schedule command and follow the instructions.\n"
"\n"
"Type /help anytime for assistance."
msgstr ""
"\n"
"\n"
"💊 Теперь давайте создадим Ваше первое расписание приема лекарств!\n"
"\n"
"Используйте команду /schedule и следуйте инструкциям.\n"
"\n"
"В любое время введите /help для получения помощи."

#: src/bot/handlers/commands/start.py:214
msgid "❌ Couldn't detect timezone. Please try again."
msgstr "❌ Не удалось определить часовой пояс. Пожалуйста, попробуйте еще раз."

#: src/bot/handlers/profile/__init__.py:19
msgid "Show your profile information"
msgstr "Мой профиль"

#: src/bot/handlers/profile/edit_hours.py:32
msgid ""
"Enter your new daylight hours (start and end) in 24-hour format:\n"
"Example: 8 22"
msgstr ""
"Введите свои новые часы бодрствования (начало и окончание) в 24-часовом "
"формате:\n"
"Например: 8 22"

#: src/bot/handlers/profile/edit_hours.py:54
msgid "❌ Edit cancelled"
msgstr "❌ Редактирование отменено"

#: src/bot/handlers/profile/edit_hours.py:66
msgid "❌ Invalid input. Please enter your new daylight hours:"
msgstr "Некорректный ввод. Пожалуйста, попробуйте еще раз:"

#: src/bot/handlers/profile/edit_hours.py:73
msgid "Please send exactly two numbers, e.g. 8 22"
msgstr "Пожалуйста, отправьте два числа, например, 8 22"

#: src/bot/handlers/profile/edit_hours.py:78
msgid "Hours must be between 0-23"
msgstr "Часы должны быть от 0 до 23"

#: src/bot/handlers/profile/edit_hours.py:80
msgid "Start hour must be before end hour"
msgstr "Начальный час должен быть раньше окончательного часа"

#: src/bot/handlers/profile/edit_hours.py:87
msgid "✅ Daylight hours updated to {start_hour:02d}:00 - {end_hour:02d}:00"
msgstr "✅ Часы бодрствования изменены на {start_hour:02d}:00 - {end_hour:02d}:00"

#: src/bot/handlers/profile/edit_hours.py:96
msgid "❌ Error"
msgstr "❌ Ошибка"

#: src/bot/handlers/profile/edit_hours.py:96
msgid "Please try again"
msgstr "Пожалуйста, попробуйте снова:"

#: src/bot/handlers/profile/keyboards.py:11
msgid "✏️ Edit Hours"
msgstr "✏️ Редактировать часы"

#: src/bot/handlers/profile/me.py:19
