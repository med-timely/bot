#: src/bot/handlers/schedules/create.py:123
msgid ""
"👋 Welcome to MedTimely!\n"
"\n"
"Before we start, please register: /start"
msgstr ""
"👋 Добро пожаловать в ПилюляБот!\n"
"\n"
"Перед началом, пожалуйста, зарегистрируйтесь: /start"

#: src/bot/handlers/schedules/create.py:133
#: src/bot/handlers/schedules/create.py:165
msgid "I couldn't parse that as a prescription. Let's continue step by step."
msgstr "Я не смог распознать это как рецепт. Продолжим по шагам."

#: src/bot/handlers/schedules/create.py:137
msgid ""
"💊 Let's create a new medication schedule.\n"
"\n"
"You can either:\n"
"1. Enter details step by step, starting with the drug name\n"
"2. Paste a prescription line (e.g. 'Take Aspirin 1 tablet 3 times daily "
"for 7 days')"
msgstr ""
"💊 Давайте создадим новое расписание приема лекарств.\n"
"\n"
"Вы можете:\n"
"1. Ввести данные по шагам, начиная с названия лекарства\n"
"2. Вставить строку рецепта (например, 'Принимать Аспирин 1 таблетка 3 "
"раза в день в течение 7 дней')"

#: src/bot/handlers/schedules/create.py:153
msgid "Please enter a valid drug name:"
msgstr "Пожалуйста, введите правильное название лекарства:"

#: src/bot/handlers/schedules/create.py:170
msgid "📏 Enter dosage (e.g. '1 tablet', '500mg'):"
msgstr "📏 Укажите дозу (например, '1 таблетка', '500мг'):"

#: src/bot/handlers/schedules/create.py:180
msgid "⏰ How many times per day? (Enter number):"
msgstr "⏰ Сколько раз в день? (Введите число):"

#: src/bot/handlers/schedules/create.py:189
msgid "Please enter a valid frequency:"
msgstr "Пожалуйста, введите правильную частоту:"

#: src/bot/handlers/schedules/create.py:198
msgid "📅 Duration in days? (Enter number):"
msgstr "📅 Сколько раз в день? (Введите число):"

#: src/bot/handlers/schedules/create.py:203
#: src/bot/handlers/schedules/create.py:223
msgid "Please enter a valid positive number:"
msgstr "Пожалуйста, введите положительное число:"

#: src/bot/handlers/schedules/create.py:209
msgid "Please enter a valid duration:"
msgstr "Пожалуйста, введите корректную длительность:"

#: src/bot/handlers/schedules/create.py:227
msgid "📝 Any comments? (Optional, type 'skip' to omit):"
msgstr ""
"📝 Дополнительные примечания? (Необязательно, введите 'пропустить' чтобы "
"пропустить):"

#: src/bot/handlers/schedules/create.py:236
msgid "Please enter a valid comment:"
msgstr "Пожалуйста, введите примечание:"

#: src/bot/handlers/schedules/create.py:264
#, python-brace-format
msgid ""
"✅ Schedule created successfully!\n"
"Next dose: {next_dose}\n"
"You'll receive reminders when it's time to take your medication."
msgstr ""
"✅ Расписание создано успешно!\n"
"Следующий прием: {next_dose}\n"
"Вы будете получать напоминания, когда придет время принять лекарство."

#: src/bot/handlers/schedules/create.py:272
msgid "No doses scheduled (schedule may be complete)"
msgstr "Нет запланированных приемов"

#: src/bot/handlers/schedules/create.py:278
#, python-brace-format
