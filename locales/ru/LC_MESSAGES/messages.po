#: src/bot/handlers/error.py:30
msgid "An error occurred while processing your message. Please try again later."
msgstr ""
"Произошла ошибка при обработке вашего сообщения. Пожалуйста, попробуйте "
"позже."

#: src/bot/handlers/commands/basic.py:15
msgid ""
"🆘 Help:\n"
"/me - Show your profile information\n"
"/schedule - Create medication schedule\n"
"/list - Show active medications\n"
"/taken - Confirm dose taken\n"
"/history - Show medication adherence history\n"
"/stop - Stop medication schedule"
msgstr ""
"🆘 Помощь:\n"
"/me - Показать информацию профиля\n"
"/schedule - Создать расписание приема лекарств\n"
"/list - Показать активные расписания\n"
"/taken - Подтвердить прием дозы\n"
"/history - Показать историю приема лекарств\n"
"/stop - Завершить прием"

#: src/bot/handlers/commands/router.py:13
msgid "Start the bot"
msgstr "Запустить бота"

#: src/bot/handlers/commands/router.py:14
msgid "Show help"
msgstr "Помощь"

#: src/bot/handlers/commands/start.py:36 src/bot/handlers/commands/start.py:76
