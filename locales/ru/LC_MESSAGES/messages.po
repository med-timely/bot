"   ⏰ On Time: {on_time}\n"
"   🕒 Late: {late}\n"
"   ❌ Missed: {missed}"
msgstr ""
"💊 {drug} ({dose}):\n"
"   ✅ Принято: {taken}/{total} ({percentage}%)\n"
"   ⏰ Вовремя: {on_time}\n"
"   🕒 С опозданием: {late}\n"
"   ❌ Пропущено: {missed}"

#: src/bot/handlers/schedules/history.py:49
msgid "Invalid input. Please provide a valid number of days."
msgstr "Некорректный ввод. Пожалуйста, укажите корректное значение."

#: src/bot/handlers/schedules/history.py:52
msgid "Please specify a positive number of days"
msgstr "Пожалуйста, введите положительное число:"

#: src/bot/handlers/schedules/history.py:55
msgid "Maximum history period is 1 year (365 days)"
msgstr "Максимальный период истории - 1 год (365 дней)"

#: src/bot/handlers/schedules/history.py:63
#, python-brace-format
msgid "No medication history found for the last {days} day"
msgid_plural "No medication history found for the last {days} days"
msgstr[0] "История приема лекарств за последний {days} день не найдена"
msgstr[1] "История приема лекарств за последний {days} дня не найдена"
msgstr[2] "История приема лекарств за последний {days} дней не найдена"

